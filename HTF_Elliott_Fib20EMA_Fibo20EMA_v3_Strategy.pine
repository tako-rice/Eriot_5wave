//@version=6
strategy("HTF Elliott Fib 20EMA Strategy EntrySwingSL OneTradePerCycle ActiveSL", overlay = true, max_labels_count = 100, max_lines_count = 100, pyramiding = 0, initial_capital = 100000, default_qty_type = strategy.percent_of_equity, default_qty_value = 10)

htf = input.timeframe("15", "Environment Timeframe")
entryTf = input.timeframe("1", "Entry Timeframe")

leftBars  = input.int(6, "HTF Swing Left Bars", minval = 1)
rightBars = input.int(6, "HTF Swing Right Bars", minval = 1)

entryLeftBars  = input.int(3, "Entry Swing Left Bars", minval = 1)
entryRightBars = input.int(3, "Entry Swing Right Bars", minval = 1)

emaLen = input.int(20, "Entry EMA Length", minval = 1)
riskReward = input.float(1.5, "Risk Reward", minval = 0.1, step = 0.1)

useWave3 = input.bool(true, "Allow Entry During Wave 3")
useWave4 = input.bool(true, "Allow Entry During Wave 4")
useFibFilter = input.bool(true, "Require Fib 0.5 / 0.618 Pullback")
showFibLevels = input.bool(true, "Show Fib 0.5 / 0.618 Levels")

showTable        = input.bool(true, "Show Status Table")
showRecentZigZag = input.bool(true, "Show Recent HTF ZigZag")
showEntrySLLine  = input.bool(true, "Show Active Trade SL Line")

upColor     = input.color(color.aqua, "Uptrend ZigZag Color")
downColor   = input.color(color.red, "Downtrend ZigZag Color")
slColor     = input.color(color.lime, "Active SL Color")
emaColor    = input.color(color.orange, "20 EMA Color")
fib50Color  = input.color(color.new(color.blue, 0), "Fib 0.5 Color")
fib618Color = input.color(color.new(color.purple, 0), "Fib 0.618 Color")

f_engine() =>
    swingHigh = ta.pivothigh(high, leftBars, rightBars)
    swingLow  = ta.pivotlow(low, leftBars, rightBars)

    var int trend = 0
    var int waveCount = 0

    var float lastPrice = na
    var float validHigh = na
    var float validLow = na

    var float pendingLowPrice = na
    var int pendingLowTime = na

    var float pendingHighPrice = na
    var int pendingHighTime = na

    var float latestSwingLowPrice = na
    var int latestSwingLowTime = na

    var float latestSwingHighPrice = na
    var int latestSwingHighTime = na

    var float pullbackSLPrice = na
    var int pullbackSLTime = na

    var int w0Time = na
    var float w0Price = na
    var int w1Time = na
    var float w1Price = na
    var int w2Time = na
    var float w2Price = na
    var int w3Time = na
    var float w3Price = na
    var int w4Time = na
    var float w4Price = na
    var int w5Time = na
    var float w5Price = na

    if not na(swingHigh)
        int pivotTime = time[rightBars]
        float pivotPrice = swingHigh

        latestSwingHighPrice := pivotPrice
        latestSwingHighTime := pivotTime

        if na(lastPrice)
            trend := 1
            waveCount := 1
            lastPrice := pivotPrice
            validHigh := pivotPrice

            if not na(latestSwingLowPrice)
                w0Time := latestSwingLowTime
                w0Price := latestSwingLowPrice

            pullbackSLPrice := na
            pullbackSLTime := na

            w1Time := pivotTime
            w1Price := pivotPrice
            w2Time := na
            w2Price := na
            w3Time := na
            w3Price := na
            w4Time := na
            w4Price := na
            w5Time := na
            w5Price := na
        else
            if trend == 1
                if not na(validHigh) and pivotPrice > validHigh
                    if not na(pendingLowPrice)
                        waveCount += 1
                        validLow := pendingLowPrice

                        if waveCount == 2
                            w2Time := pendingLowTime
                            w2Price := pendingLowPrice

                        if waveCount == 4
                            w4Time := pendingLowTime
                            w4Price := pendingLowPrice

                        pendingLowPrice := na
                        pendingLowTime := na

                        waveCount += 1
                        validHigh := pivotPrice

                        if waveCount == 3
                            w3Time := pivotTime
                            w3Price := pivotPrice

                            if not na(latestSwingLowPrice)
                                pullbackSLPrice := latestSwingLowPrice
                                pullbackSLTime := latestSwingLowTime

                        if waveCount == 5
                            w5Time := pivotTime
                            w5Price := pivotPrice
                    else
                        validHigh := pivotPrice

                        if waveCount == 1
                            if not na(latestSwingLowPrice)
                                w0Time := latestSwingLowTime
                                w0Price := latestSwingLowPrice

                            w1Time := pivotTime
                            w1Price := pivotPrice

                        if waveCount == 3
                            w3Time := pivotTime
                            w3Price := pivotPrice

                        if waveCount == 5
                            w5Time := pivotTime
                            w5Price := pivotPrice

                    lastPrice := pivotPrice

            if trend == -1
                if not na(validHigh) and pivotPrice > validHigh
                    trend := 1
                    waveCount := 1

                    validHigh := pivotPrice
                    pendingHighPrice := na
                    pendingHighTime := na
                    pendingLowPrice := na
                    pendingLowTime := na
                    lastPrice := pivotPrice

                    if not na(latestSwingLowPrice)
                        w0Time := latestSwingLowTime
                        w0Price := latestSwingLowPrice
                    else
                        w0Time := na
                        w0Price := na

                    pullbackSLPrice := na
                    pullbackSLTime := na

                    w1Time := pivotTime
                    w1Price := pivotPrice
                    w2Time := na
                    w2Price := na
                    w3Time := na
                    w3Price := na
                    w4Time := na
                    w4Price := na
                    w5Time := na
                    w5Price := na
                else
                    if na(pendingHighPrice) or pivotPrice > pendingHighPrice
                        pendingHighPrice := pivotPrice
                        pendingHighTime := pivotTime

    if not na(swingLow)
        int pivotTime = time[rightBars]
        float pivotPrice = swingLow

        latestSwingLowPrice := pivotPrice
        latestSwingLowTime := pivotTime

        if na(lastPrice)
            trend := -1
            waveCount := 1
            lastPrice := pivotPrice
            validLow := pivotPrice

            if not na(latestSwingHighPrice)
                w0Time := latestSwingHighTime
                w0Price := latestSwingHighPrice

            pullbackSLPrice := na
            pullbackSLTime := na

            w1Time := pivotTime
            w1Price := pivotPrice
            w2Time := na
            w2Price := na
            w3Time := na
            w3Price := na
            w4Time := na
            w4Price := na
            w5Time := na
            w5Price := na
        else
            if trend == -1
                if not na(validLow) and pivotPrice < validLow
                    if not na(pendingHighPrice)
                        waveCount += 1
                        validHigh := pendingHighPrice

                        if waveCount == 2
                            w2Time := pendingHighTime
                            w2Price := pendingHighPrice

                        if waveCount == 4
                            w4Time := pendingHighTime
                            w4Price := pendingHighPrice

                        pendingHighPrice := na
                        pendingHighTime := na

                        waveCount += 1
                        validLow := pivotPrice

                        if waveCount == 3
                            w3Time := pivotTime
                            w3Price := pivotPrice

                            if not na(latestSwingHighPrice)
                                pullbackSLPrice := latestSwingHighPrice
                                pullbackSLTime := latestSwingHighTime

                        if waveCount == 5
                            w5Time := pivotTime
                            w5Price := pivotPrice
                    else
                        validLow := pivotPrice

                        if waveCount == 1
                            if not na(latestSwingHighPrice)
                                w0Time := latestSwingHighTime
                                w0Price := latestSwingHighPrice

                            w1Time := pivotTime
                            w1Price := pivotPrice

                        if waveCount == 3
                            w3Time := pivotTime
                            w3Price := pivotPrice

                        if waveCount == 5
                            w5Time := pivotTime
                            w5Price := pivotPrice

                    lastPrice := pivotPrice

            if trend == 1
                if not na(validLow) and pivotPrice < validLow
                    trend := -1
                    waveCount := 1

                    validLow := pivotPrice
                    pendingLowPrice := na
                    pendingLowTime := na
                    pendingHighPrice := na
                    pendingHighTime := na
                    lastPrice := pivotPrice

                    if not na(latestSwingHighPrice)
                        w0Time := latestSwingHighTime
                        w0Price := latestSwingHighPrice
                    else
                        w0Time := na
                        w0Price := na

                    pullbackSLPrice := na
                    pullbackSLTime := na

                    w1Time := pivotTime
                    w1Price := pivotPrice
                    w2Time := na
                    w2Price := na
                    w3Time := na
                    w3Price := na
                    w4Time := na
                    w4Price := na
                    w5Time := na
                    w5Price := na
                else
                    if na(pendingLowPrice) or pivotPrice < pendingLowPrice
                        pendingLowPrice := pivotPrice
                        pendingLowTime := pivotTime

    [trend, waveCount, pullbackSLPrice, pullbackSLTime, w0Time, w0Price, w1Time, w1Price, w2Time, w2Price, w3Time, w3Price, w4Time, w4Price, w5Time, w5Price]

[htfTrend, htfWave, htfPullbackSL, htfPullbackSLTime, w0t, w0p, w1t, w1p, w2t, w2p, w3t, w3p, w4t, w4p, w5t, w5p] = request.security(syminfo.tickerid, htf, f_engine(), lookahead = barmerge.lookahead_off)

f_entryEngine() =>
    emaValue = ta.ema(close, emaLen)
    emaIsUp = emaValue > emaValue[1]
    emaIsDown = emaValue < emaValue[1]

    entrySwingHigh = ta.pivothigh(high, entryLeftBars, entryRightBars)
    entrySwingLow = ta.pivotlow(low, entryLeftBars, entryRightBars)

    var float lastEntryHigh = na
    var int lastEntryHighTime = na
    var float lastEntryLow = na
    var int lastEntryLowTime = na

    if not na(entrySwingHigh)
        lastEntryHigh := entrySwingHigh
        lastEntryHighTime := time[entryRightBars]

    if not na(entrySwingLow)
        lastEntryLow := entrySwingLow
        lastEntryLowTime := time[entryRightBars]

    longCloseCross = ta.crossover(close, emaValue)
    shortCloseCross = ta.crossunder(close, emaValue)

    [close, high, low, emaValue, emaIsUp, emaIsDown, longCloseCross, shortCloseCross, lastEntryHigh, lastEntryHighTime, lastEntryLow, lastEntryLowTime]

[entryClose, entryHigh, entryLow, entryEma20, entryEmaUp, entryEmaDown, entryLongCross, entryShortCross, entryLastHigh, entryLastHighTime, entryLastLow, entryLastLowTime] = request.security(syminfo.tickerid, entryTf, f_entryEngine(), lookahead = barmerge.lookahead_off)

plot(entryEma20, "20 EMA Entry TF", color = emaColor, linewidth = 2)

float fib50 = na
float fib618 = na

if htfTrend == 1 and not na(w2p) and not na(w3p) and w3p > w2p
    float waveRange = w3p - w2p
    fib50 := w3p - waveRange * 0.5
    fib618 := w3p - waveRange * 0.618

if htfTrend == -1 and not na(w2p) and not na(w3p) and w2p > w3p
    float waveRange = w2p - w3p
    fib50 := w3p + waveRange * 0.5
    fib618 := w3p + waveRange * 0.618

plot(showFibLevels ? fib50 : na, "Fib 0.5", color = fib50Color, linewidth = 2, style = plot.style_linebr)
plot(showFibLevels ? fib618 : na, "Fib 0.618", color = fib618Color, linewidth = 2, style = plot.style_linebr)

inTradeWave = false
if useWave3 and htfWave == 3
    inTradeWave := true
if useWave4 and htfWave == 4
    inTradeWave := true

hasFibLevels = not na(fib50) and not na(fib618)

longFibTouched = false
if htfTrend == 1 and hasFibLevels
    float fibUpper = math.max(fib50, fib618)
    float fibLower = math.min(fib50, fib618)
    if entryHigh >= fibLower and entryLow <= fibUpper
        longFibTouched := true

shortFibTouched = false
if htfTrend == -1 and hasFibLevels
    float fibUpper = math.max(fib50, fib618)
    float fibLower = math.min(fib50, fib618)
    if entryHigh >= fibLower and entryLow <= fibUpper
        shortFibTouched := true

var bool longFibReady = false
var bool shortFibReady = false
var int activeWave3Time = na

if not na(w3t)
    if na(activeWave3Time) or w3t != activeWave3Time
        activeWave3Time := w3t
        longFibReady := false
        shortFibReady := false
else
    activeWave3Time := na
    longFibReady := false
    shortFibReady := false

if inTradeWave and longFibTouched
    longFibReady := true

if inTradeWave and shortFibTouched
    shortFibReady := true

fibLongOk = not useFibFilter or longFibReady
fibShortOk = not useFibFilter or shortFibReady

longStopPrice = entryLastLow
shortStopPrice = entryLastHigh

longRisk = entryClose - longStopPrice
shortRisk = shortStopPrice - entryClose

longTakeProfit = entryClose + longRisk * riskReward
shortTakeProfit = entryClose - shortRisk * riskReward

longStopOk = not na(longStopPrice) and longStopPrice < entryClose and longRisk > syminfo.mintick
shortStopOk = not na(shortStopPrice) and shortStopPrice > entryClose and shortRisk > syminfo.mintick

var int tradedWave3Time = na
var int lastTradeDirection = 0

longCycleOk = not na(w3t) and (na(tradedWave3Time) or w3t != tradedWave3Time) and lastTradeDirection != 1
shortCycleOk = not na(w3t) and (na(tradedWave3Time) or w3t != tradedWave3Time) and lastTradeDirection != -1

longSignal = htfTrend == 1 and inTradeWave and fibLongOk and entryEmaUp and entryLongCross and longStopOk and longCycleOk and strategy.position_size == 0
shortSignal = htfTrend == -1 and inTradeWave and fibShortOk and entryEmaDown and entryShortCross and shortStopOk and shortCycleOk and strategy.position_size == 0

var float activeTradeSLPrice = na
var int activeTradeSLTime = na

tradeClosed = strategy.position_size == 0 and strategy.position_size[1] != 0

if tradeClosed
    activeTradeSLPrice := na
    activeTradeSLTime := na

if longSignal
    strategy.entry("Long", strategy.long)
    strategy.exit("Long Exit", "Long", stop = longStopPrice, limit = longTakeProfit)
    tradedWave3Time := w3t
    lastTradeDirection := 1
    longFibReady := false
    activeTradeSLPrice := longStopPrice
    activeTradeSLTime := entryLastLowTime

if shortSignal
    strategy.entry("Short", strategy.short)
    strategy.exit("Short Exit", "Short", stop = shortStopPrice, limit = shortTakeProfit)
    tradedWave3Time := w3t
    lastTradeDirection := -1
    shortFibReady := false
    activeTradeSLPrice := shortStopPrice
    activeTradeSLTime := entryLastHighTime

string trendText = htfTrend == 1 ? "UP" : htfTrend == -1 ? "DOWN" : "UNKNOWN"
string waveText = str.tostring(htfWave)
string activeSLText = na(activeTradeSLPrice) ? "N/A" : str.tostring(activeTradeSLPrice, format.mintick)
string cycleText = lastTradeDirection == 1 ? "WAIT SHORT" : lastTradeDirection == -1 ? "WAIT LONG" : "FIRST OK"

color zigzagColor = htfTrend == 1 ? upColor : htfTrend == -1 ? downColor : color.gray
color trendColor = htfTrend == 1 ? upColor : htfTrend == -1 ? downColor : color.gray
color waveBg = htfWave == 5 ? color.new(color.green, 0) : color.new(trendColor, 20)

var table statusTable = table.new(position.top_right, 2, 7, border_width = 1)

if showTable and barstate.islast
    table.cell(statusTable, 0, 0, "HTF", text_color = color.white, bgcolor = color.black)
    table.cell(statusTable, 1, 0, htf, text_color = color.white, bgcolor = color.black)

    table.cell(statusTable, 0, 1, "Trend", text_color = color.white, bgcolor = color.black)
    table.cell(statusTable, 1, 1, trendText, text_color = color.white, bgcolor = trendColor)

    table.cell(statusTable, 0, 2, "Wave", text_color = color.white, bgcolor = color.black)
    table.cell(statusTable, 1, 2, waveText, text_color = color.white, bgcolor = waveBg)

    table.cell(statusTable, 0, 3, "Active SL", text_color = color.white, bgcolor = color.black)
    table.cell(statusTable, 1, 3, activeSLText, text_color = color.black, bgcolor = slColor)

    table.cell(statusTable, 0, 4, "20 EMA", text_color = color.white, bgcolor = color.black)
    table.cell(statusTable, 1, 4, entryEmaUp ? "UP" : entryEmaDown ? "DOWN" : "FLAT", text_color = color.white, bgcolor = entryEmaUp ? upColor : entryEmaDown ? downColor : color.gray)

    table.cell(statusTable, 0, 5, "Fib Ready", text_color = color.white, bgcolor = color.black)
    table.cell(statusTable, 1, 5, longFibReady ? "LONG" : shortFibReady ? "SHORT" : "WAIT", text_color = color.white, bgcolor = longFibReady ? upColor : shortFibReady ? downColor : color.gray)

    table.cell(statusTable, 0, 6, "Cycle", text_color = color.white, bgcolor = color.black)
    table.cell(statusTable, 1, 6, cycleText, text_color = color.white, bgcolor = color.gray)

f_newLine(int x1, float y1, int x2, float y2, color c, string st, int w) =>
    line.new(x1, y1, x2, y2, xloc = xloc.bar_time, color = c, width = w, style = st == "dashed" ? line.style_dashed : st == "dotted" ? line.style_dotted : line.style_solid)

f_newLabel(int x, float y, string txt, color c, int pivotType) =>
    label.new(x, y, txt, xloc = xloc.bar_time, style = pivotType == 1 ? label.style_label_down : label.style_label_up, color = color.new(c, 75), textcolor = c, size = size.small)

var line l01 = na
var line l12 = na
var line l23 = na
var line l34 = na
var line l45 = na
var line activeSLLine = na

var label lb0 = na
var label lb1 = na
var label lb2 = na
var label lb3 = na
var label lb4 = na
var label lb5 = na
var label lbActiveSL = na
var label fib50Label = na
var label fib618Label = na

if barstate.islast
    if not na(l01)
        line.delete(l01)
        l01 := na
    if not na(l12)
        line.delete(l12)
        l12 := na
    if not na(l23)
        line.delete(l23)
        l23 := na
    if not na(l34)
        line.delete(l34)
        l34 := na
    if not na(l45)
        line.delete(l45)
        l45 := na
    if not na(activeSLLine)
        line.delete(activeSLLine)
        activeSLLine := na

    if not na(lb0)
        label.delete(lb0)
        lb0 := na
    if not na(lb1)
        label.delete(lb1)
        lb1 := na
    if not na(lb2)
        label.delete(lb2)
        lb2 := na
    if not na(lb3)
        label.delete(lb3)
        lb3 := na
    if not na(lb4)
        label.delete(lb4)
        lb4 := na
    if not na(lb5)
        label.delete(lb5)
        lb5 := na
    if not na(lbActiveSL)
        label.delete(lbActiveSL)
        lbActiveSL := na
    if not na(fib50Label)
        label.delete(fib50Label)
        fib50Label := na
    if not na(fib618Label)
        label.delete(fib618Label)
        fib618Label := na

    if showRecentZigZag
        if not na(w0t) and not na(w1t)
            l01 := f_newLine(w0t, w0p, w1t, w1p, zigzagColor, "solid", 2)
        if not na(w1t) and not na(w2t)
            l12 := f_newLine(w1t, w1p, w2t, w2p, zigzagColor, "solid", 2)
        if not na(w2t) and not na(w3t)
            l23 := f_newLine(w2t, w2p, w3t, w3p, zigzagColor, "solid", 2)
        if not na(w3t) and not na(w4t)
            l34 := f_newLine(w3t, w3p, w4t, w4p, zigzagColor, "solid", 2)
        if not na(w4t) and not na(w5t)
            l45 := f_newLine(w4t, w4p, w5t, w5p, zigzagColor, "solid", 2)

        if not na(w0t)
            lb0 := f_newLabel(w0t, w0p, "0", zigzagColor, htfTrend == 1 ? -1 : 1)
        if not na(w1t)
            lb1 := f_newLabel(w1t, w1p, "1", zigzagColor, htfTrend == 1 ? 1 : -1)
        if not na(w2t)
            lb2 := f_newLabel(w2t, w2p, "2", zigzagColor, htfTrend == 1 ? -1 : 1)
        if not na(w3t)
            lb3 := f_newLabel(w3t, w3p, "3", zigzagColor, htfTrend == 1 ? 1 : -1)
        if not na(w4t)
            lb4 := f_newLabel(w4t, w4p, "4", zigzagColor, htfTrend == 1 ? -1 : 1)
        if not na(w5t)
            lb5 := f_newLabel(w5t, w5p, "5", zigzagColor, htfTrend == 1 ? 1 : -1)

    if showEntrySLLine and strategy.position_size != 0 and not na(activeTradeSLPrice) and not na(activeTradeSLTime)
        activeSLLine := f_newLine(activeTradeSLTime, activeTradeSLPrice, time, activeTradeSLPrice, slColor, "solid", 3)
        line.set_extend(activeSLLine, extend.right)
        lbActiveSL := f_newLabel(activeTradeSLTime, activeTradeSLPrice, "Active SL", slColor, strategy.position_size > 0 ? -1 : 1)

    if showFibLevels and not na(fib50)
        fib50Label := label.new(time, fib50, "Fib 0.5", xloc = xloc.bar_time, style = label.style_label_left, color = fib50Color, textcolor = color.white, size = size.small)

    if showFibLevels and not na(fib618)
        fib618Label := label.new(time, fib618, "Fib 0.618", xloc = xloc.bar_time, style = label.style_label_left, color = fib618Color, textcolor = color.white, size = size.small)
