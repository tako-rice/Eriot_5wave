//@version=6
indicator("Elliott Swing Count + Ignore v5", overlay = true, max_labels_count = 500, max_lines_count = 500)

leftBars  = input.int(6, "Swing Left Bars", minval = 1)
rightBars = input.int(6, "Swing Right Bars", minval = 1)

showCountLabels  = input.bool(true, "Show Count Labels")
showIgnoreLabels = input.bool(true, "Show Ignore Labels")
showLines        = input.bool(true, "Show Count Lines")

upColor     = input.color(color.aqua, "Uptrend Count Color")
downColor   = input.color(color.red, "Downtrend Count Color")
ignoreColor = input.color(color.gray, "Ignore Color")
lineColor   = input.color(color.white, "Line Color")
lineWidth   = input.int(2, "Line Width", minval = 1, maxval = 5)

labelAtrOffset = input.float(0.45, "Label Offset ATR", minval = 0.0, step = 0.05)

swingHigh = ta.pivothigh(high, leftBars, rightBars)
swingLow  = ta.pivotlow(low, leftBars, rightBars)

atrValue = ta.atr(14)
labelOffset = atrValue * labelAtrOffset

var int trend = 0
var int waveCount = 0

var int lastType = 0
var int lastBar = na
var float lastPrice = na

var float validHigh = na
var float validLow = na

var int pendingLowBar = na
var float pendingLowPrice = na
var label pendingLowLabel = na

var int pendingHighBar = na
var float pendingHighPrice = na
var label pendingHighLabel = na

var label lastCountLabel = na
var line lastLine = na

f_countLabel(int x, float y, int pivotType, int trendDir, int countNum) =>
    label lb = na
    color c = trendDir == 1 ? upColor : downColor
    string txt = str.tostring(countNum)

    if pivotType == 1
        lb := label.new(x, y + labelOffset, txt, style = label.style_label_down, color = color.new(c, 80), textcolor = c, size = size.small)

    if pivotType == -1
        lb := label.new(x, y - labelOffset, txt, style = label.style_label_up, color = color.new(c, 80), textcolor = c, size = size.small)

    lb

f_ignoreLabel(int x, float y, int pivotType) =>
    label lb = na

    if pivotType == 1
        lb := label.new(x, y + labelOffset, "無視", style = label.style_label_down, color = color.new(ignoreColor, 88), textcolor = ignoreColor, size = size.tiny)

    if pivotType == -1
        lb := label.new(x, y - labelOffset, "無視", style = label.style_label_up, color = color.new(ignoreColor, 88), textcolor = ignoreColor, size = size.tiny)

    lb

f_drawLine(int x1, float y1, int x2, float y2) =>
    line ln = na

    if showLines
        ln := line.new(x1, y1, x2, y2, color = lineColor, width = lineWidth)

    ln

//--------------------------------------------------
// Swing High
//--------------------------------------------------
if not na(swingHigh)
    int pivotBar = bar_index - rightBars
    float pivotPrice = swingHigh

    if na(lastPrice)
        trend := 1
        waveCount := 1
        lastType := 1
        lastBar := pivotBar
        lastPrice := pivotPrice
        validHigh := pivotPrice

        if showCountLabels
            lastCountLabel := f_countLabel(pivotBar, pivotPrice, 1, trend, waveCount)

    else
        if trend == 1
            if not na(validHigh) and pivotPrice > validHigh
                if not na(pendingLowPrice)
                    if not na(pendingLowLabel)
                        label.delete(pendingLowLabel)
                        pendingLowLabel := na

                    waveCount += 1

                    if showLines
                        lastLine := f_drawLine(lastBar, lastPrice, pendingLowBar, pendingLowPrice)

                    if showCountLabels
                        lastCountLabel := f_countLabel(pendingLowBar, pendingLowPrice, -1, trend, waveCount)

                    lastType := -1
                    lastBar := pendingLowBar
                    lastPrice := pendingLowPrice
                    validLow := pendingLowPrice

                    pendingLowBar := na
                    pendingLowPrice := na

                    waveCount += 1

                    if showLines
                        lastLine := f_drawLine(lastBar, lastPrice, pivotBar, pivotPrice)

                    if showCountLabels
                        lastCountLabel := f_countLabel(pivotBar, pivotPrice, 1, trend, waveCount)

                    lastType := 1
                    lastBar := pivotBar
                    lastPrice := pivotPrice
                    validHigh := pivotPrice
                else
                    if not na(lastCountLabel)
                        label.delete(lastCountLabel)
                        lastCountLabel := na

                    if not na(lastLine)
                        line.set_x2(lastLine, pivotBar)
                        line.set_y2(lastLine, pivotPrice)

                    if showCountLabels
                        lastCountLabel := f_countLabel(pivotBar, pivotPrice, 1, trend, waveCount)

                    lastType := 1
                    lastBar := pivotBar
                    lastPrice := pivotPrice
                    validHigh := pivotPrice
            else
                if showIgnoreLabels
                    f_ignoreLabel(pivotBar, pivotPrice, 1)

        if trend == -1
            if not na(validHigh) and pivotPrice > validHigh
                trend := 1
                waveCount := 1

                pendingHighBar := na
                pendingHighPrice := na
                pendingLowBar := na
                pendingLowPrice := na

                if not na(pendingHighLabel)
                    label.delete(pendingHighLabel)
                    pendingHighLabel := na

                if not na(pendingLowLabel)
                    label.delete(pendingLowLabel)
                    pendingLowLabel := na

                if showLines
                    lastLine := f_drawLine(lastBar, lastPrice, pivotBar, pivotPrice)

                if showCountLabels
                    lastCountLabel := f_countLabel(pivotBar, pivotPrice, 1, trend, waveCount)

                lastType := 1
                lastBar := pivotBar
                lastPrice := pivotPrice
                validHigh := pivotPrice
            else
                if na(pendingHighPrice) or pivotPrice > pendingHighPrice
                    pendingHighBar := pivotBar
                    pendingHighPrice := pivotPrice

                if showIgnoreLabels
                    pendingHighLabel := f_ignoreLabel(pivotBar, pivotPrice, 1)

//--------------------------------------------------
// Swing Low
//--------------------------------------------------
if not na(swingLow)
    int pivotBar = bar_index - rightBars
    float pivotPrice = swingLow

    if na(lastPrice)
        trend := -1
        waveCount := 1
        lastType := -1
        lastBar := pivotBar
        lastPrice := pivotPrice
        validLow := pivotPrice

        if showCountLabels
            lastCountLabel := f_countLabel(pivotBar, pivotPrice, -1, trend, waveCount)

    else
        if trend == -1
            if not na(validLow) and pivotPrice < validLow
                if not na(pendingHighPrice)
                    if not na(pendingHighLabel)
                        label.delete(pendingHighLabel)
                        pendingHighLabel := na

                    waveCount += 1

                    if showLines
                        lastLine := f_drawLine(lastBar, lastPrice, pendingHighBar, pendingHighPrice)

                    if showCountLabels
                        lastCountLabel := f_countLabel(pendingHighBar, pendingHighPrice, 1, trend, waveCount)

                    lastType := 1
                    lastBar := pendingHighBar
                    lastPrice := pendingHighPrice
                    validHigh := pendingHighPrice

                    pendingHighBar := na
                    pendingHighPrice := na

                    waveCount += 1

                    if showLines
                        lastLine := f_drawLine(lastBar, lastPrice, pivotBar, pivotPrice)

                    if showCountLabels
                        lastCountLabel := f_countLabel(pivotBar, pivotPrice, -1, trend, waveCount)

                    lastType := -1
                    lastBar := pivotBar
                    lastPrice := pivotPrice
                    validLow := pivotPrice
                else
                    if not na(lastCountLabel)
                        label.delete(lastCountLabel)
                        lastCountLabel := na

                    if not na(lastLine)
                        line.set_x2(lastLine, pivotBar)
                        line.set_y2(lastLine, pivotPrice)

                    if showCountLabels
                        lastCountLabel := f_countLabel(pivotBar, pivotPrice, -1, trend, waveCount)

                    lastType := -1
                    lastBar := pivotBar
                    lastPrice := pivotPrice
                    validLow := pivotPrice
            else
                if showIgnoreLabels
                    f_ignoreLabel(pivotBar, pivotPrice, -1)

        if trend == 1
            if not na(validLow) and pivotPrice < validLow
                trend := -1
                waveCount := 1

                pendingLowBar := na
                pendingLowPrice := na
                pendingHighBar := na
                pendingHighPrice := na

                if not na(pendingLowLabel)
                    label.delete(pendingLowLabel)
                    pendingLowLabel := na

                if not na(pendingHighLabel)
                    label.delete(pendingHighLabel)
                    pendingHighLabel := na

                if showLines
                    lastLine := f_drawLine(lastBar, lastPrice, pivotBar, pivotPrice)

                if showCountLabels
                    lastCountLabel := f_countLabel(pivotBar, pivotPrice, -1, trend, waveCount)

                lastType := -1
                lastBar := pivotBar
                lastPrice := pivotPrice
                validLow := pivotPrice
            else
                if na(pendingLowPrice) or pivotPrice < pendingLowPrice
                    pendingLowBar := pivotBar
                    pendingLowPrice := pivotPrice

                if showIgnoreLabels
                    pendingLowLabel := f_ignoreLabel(pivotBar, pivotPrice, -1)
